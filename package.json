{
  "name": "runmapper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Plan, edit, and save running routes as GPX files. iPad-friendly PWA powered by MapLibre and BRouter.",
  "scripts": {
    "dev": "vite",
    "dev:https": "VITE_HTTPS=1 vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:https": "VITE_HTTPS=1 vite preview --host",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "idb": "^8.0.0",
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "workbox-window": "^7.3.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
